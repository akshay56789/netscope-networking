# Flask Configuration
FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=super-secret-key-change-in-production

# Local Development Database (SQLite)
# Uncomment the line below to use SQLite locally
SQLALCHEMY_DATABASE_URI=sqlite:///netscope.db

# Production Database (MySQL)
# Uncomment and configure the lines below for MySQL
# DB_HOST=your-mysql-server.mysql.database.azure.com
# DB_PORT=3306
# DB_NAME=netscope_db
# DB_USER=admin_user
# DB_PASSWORD=your_password
